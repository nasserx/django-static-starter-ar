# Environment example for this starter template.
#
# Django does not automatically load this file. Export these variables in
# your shell, deployment platform, or external env-loading tool if you want
# backend/config/settings.py to see them.
#
# Never commit real secrets in .env files.

# Backend settings supported by backend/config/settings.py:
# DJANGO_SECRET_KEY=change-me-to-a-generated-secret-key
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Optional backend security hardening knobs. Defaults are local-development friendly.
# Enable secure cookies and SSL redirect only when serving Django over HTTPS.
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_SESSION_COOKIE_SECURE=false
# DJANGO_CSRF_COOKIE_SECURE=false
# DJANGO_SECURE_HSTS_SECONDS=0
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
# DJANGO_SECURE_HSTS_PRELOAD=false
# DJANGO_SECURE_REFERRER_POLICY=same-origin

# Static frontend config is not read from env files by browser JavaScript.
# BACKEND_API_BASE_URL=http://127.0.0.1:8000
