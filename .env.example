# Environment example for this starter template.
#
# Current runtime behavior:
# - backend/config/settings.py does not read this file yet.
# - frontend/src/js/config.js does not read env files because the frontend is static JS.
# - Copy this file only as a safe local placeholder if a future branch adds env loading.
#
# Never commit real secrets in .env files.

# Future backend examples, not currently consumed:
# DJANGO_SECRET_KEY=change-me
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Future frontend/static config example, not currently consumed:
# BACKEND_API_BASE_URL=http://127.0.0.1:8000
